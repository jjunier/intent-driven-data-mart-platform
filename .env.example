# Anthropic
ANTHROPIC_API_KEY=your_api_key_here

# Data Warehouse connection (choose one)
DW_TYPE=bigquery           # bigquery | snowflake | redshift | duckdb
DW_PROJECT=your_project
DW_DATASET=your_dataset
DW_CREDENTIALS_PATH=path/to/credentials.json

# App
APP_ENV=development        # development | production
LOG_LEVEL=INFO
